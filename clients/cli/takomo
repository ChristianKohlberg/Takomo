cmd_token_create() {
  local actor="" scopes="read,write" projects="" expires=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --actor)    actor=$2; shift 2 ;;
      --scopes)   scopes=$2; shift 2 ;;
      --projects) projects=$2; shift 2 ;;
      --expires)  expires=$2; shift 2 ;;
      -*) die "token create: unknown flag $1" ;;
      *) die "token create: unexpected argument '$1'" ;;
    esac
  done
  [ -n "$actor" ] || die "token create: --actor NAME is required"
  local data
  data=$(TS_ACTOR="$actor" TS_SCOPES="$scopes" TS_PROJECTS="$projects" TS_EXPIRES="$expires" python3 <<'PY'
import json, os
d = {"actor": os.environ["TS_ACTOR"]}
d["scopes"] = [s for s in os.environ["TS_SCOPES"].split(",") if s.strip()]
proj = os.environ.get("TS_PROJECTS", "").strip()
if proj and proj != "*":
    d["projects"] = [p for p in proj.split(",") if p.strip()]
exp = os.environ.get("TS_EXPIRES", "").strip()
if exp:
    units = {"d": 86400, "h": 3600, "m": 60, "s": 1}
    if exp[-1] in units and exp[:-1].isdigit():
        d["expires_seconds"] = int(exp[:-1]) * units[exp[-1]]
    elif exp.isdigit():
        d["expires_seconds"] = int(exp)
    else:
        raise SystemExit(f"invalid --expires '{exp}': use 90d, 12h, 30m, 3600s, or a plain second count")
print(json.dumps(d))
PY
)
  api POST /v1/tokens "$data" >/dev/null
  python3 - "$REQ_OUT" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
proj = d.get("projects")
proj = "*" if proj == "*" else ", ".join(proj) if isinstance(proj, list) else proj
print(f"token id:  {d.get('id','')}")
print(f"actor:     {d.get('actor','')}")
print(f"scopes:    {', '.join(d.get('scopes', []))}")
print(f"projects:  {proj}")
print(f"expires:   {d.get('expires_at') or 'never'}")
print(f"rate:      {d.get('rate_limit','?')}/min writes")
print()
print(d.get("token", ""))
print()
print(d.get("warning", "This plaintext is shown once; only its hash is stored."))
PY
}

cmd_token_ls() {
  api GET /v1/tokens >/dev/null
