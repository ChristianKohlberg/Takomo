#!/usr/bin/env bash
# takomo — a friendly command-line client for the takomo.
#
# A single self-contained wrapper over the REST API so a human or an agent can
# work the queue without hand-writing curl. It is the beads/beans-equivalent
# surface for the takomo: create, search, claim, and progress tickets.
#
# Transport is curl (its default User-Agent sails past WAFs that block the
# python-urllib default UA). python3 is used only locally, to build request
# bodies and format responses — never to make the HTTP request itself.
#
# Environment:
#   TAKOMO_URL      required. The /v1 base, e.g. https://host/v1
#   TAKOMO_TOKEN    required. A read/write (and, for gated moves, human) token.
#   TAKOMO_PROJECT  optional. Default project when --project is omitted.
#   TAKOMO_ACTOR    optional. Your actor name; only needed for `ls --mine`.
#
# Repo-local config: after `takomo init`, url/project/token are read from a
# `.takomo/` directory (walking up from the cwd) so plain `takomo new`/`takomo ready`
# just work inside that repo. Precedence is explicit flag > environment >
# `.takomo` config.
#
# The fence for a claimed ticket is remembered locally (keyed by store URL +
# ticket id) so start/done/comment/link "just work" after a claim without you
# passing --fence. Override or supply it explicitly with --fence N.
#
# Dependencies: bash, curl, python3 (stdlib only; PyYAML only if you pass a
# custom .yaml workflow to `takomo init`).
set -euo pipefail

PROG=takomo
die() { echo "$PROG: $*" >&2; exit 2; }

# --- repo-local config (.takomo) -----------------------------------------
# Walk up from the cwd for a `.takomo/config` (KEY=VALUE) and `.takomo/token`.
# Only fills TAKOMO_URL/PROJECT/TOKEN that are not already set in the
# environment, so env (and thus any explicit override) always wins.
load_takomo_config() {
  local dir="$PWD" cfg="" tok=""
  while [ -n "$dir" ]; do
    if [ -f "$dir/.takomo/config" ]; then cfg="$dir/.takomo/config"; tok="$dir/.takomo/token"; break; fi
    [ "$dir" = "/" ] && break
    dir=$(dirname "$dir")
  done
  [ -n "$cfg" ] || return 0
  local url proj
  url=$(sed -n 's/^url=//p' "$cfg" | tail -1)
  proj=$(sed -n 's/^project=//p' "$cfg" | tail -1)
  [ -z "${TAKOMO_URL:-}" ] && [ -n "$url" ] && export TAKOMO_URL="$url"
  [ -z "${TAKOMO_PROJECT:-}" ] && [ -n "$proj" ] && export TAKOMO_PROJECT="$proj"
  if [ -z "${TAKOMO_TOKEN:-}" ] && [ -f "$tok" ]; then
    TAKOMO_TOKEN="$(cat "$tok")"
    export TAKOMO_TOKEN
  fi
}

# --- local fence store -------------------------------------------------------
fence_dir() {
  local base="${XDG_STATE_HOME:-$HOME/.local/state}/takomo/fences"
  if mkdir -p "$base" 2>/dev/null; then echo "$base"; return; fi
  base="/tmp/takomo-${UID:-$(id -u)}/fences"
  mkdir -p "$base"
  echo "$base"
}
fence_file() {
  local id=$1 urlkey
  urlkey=$(printf '%s' "${TAKOMO_URL:-}" | cksum | cut -d' ' -f1)
  echo "$(fence_dir)/${urlkey}_${id}"
}
fence_save() { printf '%s' "$2" > "$(fence_file "$1")"; }
fence_load() { local f; f=$(fence_file "$1"); if [ -f "$f" ]; then cat "$f"; fi; }
fence_clear() { rm -f "$(fence_file "$1")" 2>/dev/null || true; }

# --- HTTP --------------------------------------------------------------------
REQ_OUT=$(mktemp)
trap 'rm -f "$REQ_OUT"' EXIT

# api METHOD PATH [JSON_DATA] [EXTRA_HEADER]
# Writes the raw body to $REQ_OUT and echoes the HTTP status code on stdout.
# On any >=400 it prints the store's teaching error (code/message/remedy/
# allowed_transitions) to stderr and exits nonzero, so callers never have to
# guard against error bodies.
api() {
  local method=$1 path=$2 data=${3:-} extra=${4:-} code
  local -a args=(-sS -o "$REQ_OUT" -w '%{http_code}' -X "$method"
    "$TAKOMO_URL$path" -H "Authorization: Bearer $TAKOMO_TOKEN")
  [ -n "$extra" ] && args+=(-H "$extra")
  if [ -n "$data" ]; then
    args+=(-H "Content-Type: application/json" --data-binary "$data")
  fi
  code=$(curl "${args[@]}") || die "request failed (network/curl error)"
  if [ "$code" -ge 400 ]; then
    python3 - "$REQ_OUT" "$code" >&2 <<'PY'
import json, sys
tmp, code = sys.argv[1], sys.argv[2]
try:
    d = json.load(open(tmp))
except Exception:
    print(f"HTTP {code}: {open(tmp).read()[:800]}"); sys.exit(1)
print(f"HTTP {code}  [{d.get('code','?')}]")
if d.get('message'): print(d['message'])
if d.get('remedy'):  print("remedy: " + d['remedy'])
if d.get('current_state'): print("current state: " + d['current_state'])
for t in d.get('allowed_transitions', []):
    req = (" (requires " + ", ".join(t['requires']) + ")") if t.get('requires') else ""
    print(f"  allowed -> {t['to']}{req}")
PY
    exit 1
  fi
  echo "$code"
}

# Like api(), but never exits on an error status — returns the HTTP code on
# stdout (or "000" on a curl failure) and leaves the body in $REQ_OUT. Used by
# the importer's best-effort relation/state passes, where one item failing must
# not abort the whole run.
api_try() {
  local method=$1 path=$2 data=${3:-} extra=${4:-} code
  local -a args=(-sS -o "$REQ_OUT" -w '%{http_code}' -X "$method"
    "$TAKOMO_URL$path" -H "Authorization: Bearer $TAKOMO_TOKEN")
  [ -n "$extra" ] && args+=(-H "$extra")
  if [ -n "$data" ]; then
    args+=(-H "Content-Type: application/json" --data-binary "$data")
  fi
  code=$(curl "${args[@]}") || { echo "000"; return 0; }
  echo "$code"
}

# Print the store's teaching message from the last $REQ_OUT body to stderr,
# indented, for the importer's soft failures.
print_api_error() {
  python3 - "$REQ_OUT" >&2 <<'PY'
import json, sys
try:
    d = json.load(open(sys.argv[1]))
except Exception:
    print("    " + open(sys.argv[1]).read()[:300]); sys.exit()
if d.get('message'):
    print("    " + d['message'][:400])
PY
}

require_env() {
  load_takomo_config
  [ -n "${TAKOMO_URL:-}" ]   || die "TAKOMO_URL is not set (e.g. https://host or https://host/v1). Run 'takomo init' in a git repo, or export it."
  [ -n "${TAKOMO_TOKEN:-}" ] || die "TAKOMO_TOKEN is not set. Run 'takomo init', or export a token."
  # Normalize to the host root: paths below always carry their own /v1, so we
  # accept TAKOMO_URL with or without a trailing /v1 (and trailing slash).
  TAKOMO_URL="${TAKOMO_URL%/}"
  TAKOMO_URL="${TAKOMO_URL%/v1}"
}

resolve_project() {
  local p=${1:-}
  [ -n "$p" ] && { echo "$p"; return; }
  [ -n "${TAKOMO_PROJECT:-}" ] && { echo "$TAKOMO_PROJECT"; return; }
  die "no project given; pass --project P or set TAKOMO_PROJECT"
}

# urlencode a single query value
urlenc() { python3 -c 'import sys,urllib.parse as u; print(u.quote(sys.argv[1], safe=""))' "$1"; }

# --- commands ----------------------------------------------------------------

cmd_new() {
  local project="" type="" priority="" parent="" body=""
  local -a labels=()
  local title=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project=$2; shift 2 ;;
      --type)    type=$2; shift 2 ;;
      --priority) priority=$2; shift 2 ;;
      --parent)  parent=$2; shift 2 ;;
      --body)    body=$2; shift 2 ;;
      --label)   labels+=("$2"); shift 2 ;;
      --) shift; break ;;
      -*) die "new: unknown flag $1" ;;
      *) title=$1; shift ;;
    esac
  done
  [ -n "$title" ] || die "new: TITLE is required"
  project=$(resolve_project "$project")
  local idem; idem="takomo-cli-$(date +%s)-$RANDOM"
  local data
  data=$(TS_PROJECT="$project" TS_TYPE="$type" TS_TITLE="$title" TS_BODY="$body" \
    TS_PRIORITY="$priority" TS_PARENT="$parent" \
    TS_LABELS="$(printf '%s\n' "${labels[@]+"${labels[@]}"}")" python3 <<'PY'
import json, os
d = {"project": os.environ["TS_PROJECT"], "title": os.environ["TS_TITLE"]}
for env, key in (("TS_TYPE","type"),("TS_PRIORITY","priority"),("TS_PARENT","parent")):
    v = os.environ.get(env, "").strip()
    if v: d[key] = v
if os.environ.get("TS_BODY", ""): d["body"] = os.environ["TS_BODY"]
labels = [l for l in os.environ.get("TS_LABELS","").splitlines() if l.strip()]
if labels: d["labels"] = labels
print(json.dumps(d))
PY
)
  api POST /v1/tickets "$data" "Idempotency-Key: $idem" >/dev/null
  python3 - "$REQ_OUT" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
print(f"created {d['id']}  [{d['state']}]  {d['title']}")
sim = d.get("similar") or []
if sim:
    print("\npossible duplicates (search before creating):")
    for s in sim:
        print(f"  {s.get('id')}  [{s.get('state','?')}]  {s.get('title','')}")
PY
}

cmd_ls() {
  local project="" state="" q="" mine="" archived=""
  local -a labels=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project=$2; shift 2 ;;
      --state)   state=$2; shift 2 ;;
      --label)   labels+=("$2"); shift 2 ;;
      --mine)    mine=1; shift ;;
      --archived) archived=1; shift ;;
      -q|--query) q=$2; shift 2 ;;
      -*) die "ls: unknown flag $1" ;;
      *) die "ls: unexpected argument '$1'" ;;
    esac
  done
  local qs="?limit=100"
  [ -n "$project" ] && qs="$qs&project=$(urlenc "$project")"
  [ -z "$project" ] && [ -n "${TAKOMO_PROJECT:-}" ] && qs="$qs&project=$(urlenc "$TAKOMO_PROJECT")"
  [ -n "$state" ] && qs="$qs&state=$(urlenc "$state")"
  [ -n "$archived" ] && qs="$qs&archived=only"
  [ -n "$q" ] && qs="$qs&q=$(urlenc "$q")"
  for l in "${labels[@]+"${labels[@]}"}"; do qs="$qs&label=$(urlenc "$l")"; done
  if [ -n "$mine" ]; then
    [ -n "${TAKOMO_ACTOR:-}" ] || die "ls --mine needs TAKOMO_ACTOR set to your actor name"
    qs="$qs&claimed_by=$(urlenc "$TAKOMO_ACTOR")"
  fi
  api GET "/v1/tickets$qs" >/dev/null
  python3 - "$REQ_OUT" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
items = d.get("items", [])
if not items:
    print("(no tickets)"); sys.exit()
def trunc(s, n): return s if len(s) <= n else s[:n-1] + "…"
print(f"{'ID':<14} {'STATE':<12} {'PRI':<8} {'TYPE':<6} TITLE")
for t in items:
    claim = t.get("claim") or {}
    holder = f"  @{claim['holder']}" if claim else ""
    print(f"{t['id']:<14} {t.get('state',''):<12} {t.get('priority',''):<8} "
          f"{t.get('type',''):<6} {trunc(t.get('title',''),56)}{holder}")
if d.get("next_cursor"):
    print(f"\n(more results; next_cursor={d['next_cursor']})")
PY
}

cmd_ready() {
  local project=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project=$2; shift 2 ;;
      -*) die "ready: unknown flag $1" ;;
      *) die "ready: unexpected argument '$1'" ;;
    esac
  done
  local qs="?limit=50"
  project=$(resolve_project "$project")
  qs="$qs&project=$(urlenc "$project")"
  api GET "/v1/ready$qs" >/dev/null
  python3 - "$REQ_OUT" <<'PY'
import json, sys
items = json.load(open(sys.argv[1]))
if not items:
    print("(ready queue empty)"); sys.exit()
def trunc(s, n): return s if len(s) <= n else s[:n-1] + "…"
print(f"{'ID':<14} {'PRI':<8} {'TYPE':<6} TITLE")
for t in items:
    print(f"{t['id']:<14} {t.get('priority',''):<8} {t.get('type',''):<6} {trunc(t.get('title',''),60)}")
PY
}

cmd_roadmap() {
  local project=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project=$2; shift 2 ;;
      -*) die "roadmap: unknown flag $1" ;;
      *) die "roadmap: unexpected argument '$1'" ;;
    esac
  done
  project=$(resolve_project "$project")
  api GET "/v1/projects/$(urlenc "$project")/roadmap" >/dev/null
  python3 - "$REQ_OUT" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
epics = d.get("epics", [])
unparented = d.get("unparented") or {}
print(f"roadmap for {d.get('project','')}  ({len(epics)} epic(s))")
def bar(pct, width=10):
    filled = int(round(pct / 100.0 * width))
    filled = max(0, min(width, filled))
    return "[" + "#" * filled + "-" * (width - filled) + "]"
def trunc(s, n): return s if len(s) <= n else s[:n-1] + "..."
def rollup(r, label="children by state", indent="  "):
    total = r.get("total", 0); done = r.get("done", 0); pct = r.get("percent", 0)
    print(f"{indent}{bar(pct)} {done}/{total} done  ({pct}%)")
    bs = r.get("by_state") or {}
    if bs:
        print(f"{indent}{label}: " + ", ".join(f"{k}={v}" for k, v in sorted(bs.items())))
if not epics:
    print("(no epics)")
for e in epics:
    flags = e.get("flags") or []
    suffix = "  !" + ",".join(flags) if flags else ""
    print(f"\n{e['id']}  [{e.get('state','')}]  {trunc(e.get('title',''), 52)}{suffix}")
    rollup(e)
# Work that belongs to no epic is real work: show it even when it is empty, so
# an empty bucket reads as "all accounted for" rather than as a missing row.
print(f"\n(no epic)  {unparented.get('total', 0)} ticket(s) outside every epic")
rollup(unparented, "tickets by state")
PY
}

cmd_show() {
  local id=${1:-}; [ -n "$id" ] || die "show: ID is required"
  api GET "/v1/tickets/$(urlenc "$id")?include=comments,deps,children" >/dev/null
  python3 - "$REQ_OUT" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
print(f"{d['id']}  [{d.get('state','')}]  ({d.get('type','')}, {d.get('priority','')})")
print(f"  project: {d.get('project','')}   version: {d.get('version','')}")
if d.get("parent"): print(f"  parent:  {d['parent']}")
if d.get("labels"): print(f"  labels:  {', '.join(d['labels'])}")
claim = d.get("claim")
if claim: print(f"  claim:   @{claim['holder']} until {claim.get('expires_at','')}")
links = d.get("links") or {}
if links: print("  links:   " + ", ".join(f"{k}={v}" for k, v in links.items()))
if d.get("title"): print(f"\n  {d['title']}")
if d.get("body"): print("\n" + "\n".join("  " + l for l in d["body"].splitlines()))
deps = d.get("deps") or {}
bb = deps.get("blocked_by") or []
if bb:
    print("\nblocked by:")
    for b in bb: print(f"  {b['id']}  [{b.get('state','')}]  {b.get('title','')}")
ch = d.get("children") or []
if ch:
    print("\nchildren:")
    for c in ch: print(f"  {c['id']}  [{c.get('state','')}]  {c.get('title','')}")
cs = d.get("comments") or []
if cs:
    print("\ncomments:")
    for c in cs:
        print(f"  [{c.get('created_at','')}] @{c.get('author','')}: {c.get('body','')}")
PY
}

# save the fence emitted by a claim/ready-claim response for ticket $1
save_fence_from_response() {
  local id=$1 fence
  fence=$(python3 - "$REQ_OUT" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
lease = d.get("lease", d)  # ready/claim nests it; claim returns the lease itself
f = lease.get("fence")
print(f if f is not None else "")
PY
)
  [ -n "$fence" ] && fence_save "$id" "$fence"
  echo "$fence"
}

cmd_claim() {
  local id=${1:-}; [ -n "$id" ] || die "claim: ID is required"
  api POST "/v1/tickets/$(urlenc "$id")/claim" '{}' >/dev/null
  local fence; fence=$(save_fence_from_response "$id")
  echo "claimed $id  (fence $fence saved)"
}

cmd_next() {
  local project="" wait="0"
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project=$2; shift 2 ;;
      --wait)    wait=$2; shift 2 ;;
      -*) die "next: unknown flag $1" ;;
      *) die "next: unexpected argument '$1'" ;;
    esac
  done
  project=$(resolve_project "$project")
  local data; data=$(TS_P="$project" TS_W="$wait" python3 -c \
    'import json,os; print(json.dumps({"project":os.environ["TS_P"],"wait_seconds":int(os.environ["TS_W"])}))')
  local code; code=$(api POST /v1/ready/claim "$data")
  if [ "$code" = "204" ]; then echo "(nothing ready to claim)"; return; fi
  local id; id=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["id"])' "$REQ_OUT")
  local fence; fence=$(save_fence_from_response "$id")
  python3 - "$REQ_OUT" "$fence" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
print(f"claimed {d['id']}  [{d.get('state','')}]  {d.get('title','')}  (fence {sys.argv[2]} saved)")
PY
}

# transition ID TO_STATE — auto-echoes the stored fence; clears it on terminal.
do_transition() {
  local id=$1 to=$2 reason=${3:-} fence
  fence=$(fence_load "$id")
  local data; data=$(TS_TO="$to" TS_REASON="$reason" TS_FENCE="$fence" python3 <<'PY'
import json, os
d = {"to": os.environ["TS_TO"]}
if os.environ.get("TS_REASON",""): d["reason"] = os.environ["TS_REASON"]
if os.environ.get("TS_FENCE",""): d["fence"] = int(os.environ["TS_FENCE"])
print(json.dumps(d))
PY
)
  api POST "/v1/tickets/$(urlenc "$id")/transition" "$data" >/dev/null
  local newstate; newstate=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["state"])' "$REQ_OUT")
  case "$newstate" in done|cancelled) fence_clear "$id" ;; esac
  # If the server auto-released the claim on this move, drop the local fence too.
  python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); sys.exit(0 if d.get("claim") else 1)' "$REQ_OUT" \
    || fence_clear "$id"
  echo "$id -> $newstate"
}

# --- workflow-aware state resolution -----------------------------------------
# The convenience verbs (start / done / block / cancel) must work across
# different workflows: `simple` uses in_progress/blocked/done, `factory-default`
# uses implementing/needs-decision/done. Rather than hard-coding state ids, we
# read the project's workflow and resolve the target by *category*, among the
# transitions actually legal from the ticket's current state. This mirrors the
# MCP server's targetsInCategory()/advanceToCategory() resolution (clients/mcp).

# Fetch a project's workflow into $2 (a file path) so later api calls overwriting
# $REQ_OUT do not clobber it.
wf_fetch() {
  local project=$1 dest=$2
  api GET "/v1/projects/$(urlenc "$project")/workflow" >/dev/null
  cp "$REQ_OUT" "$dest"
}

# Echo one field of a workflow state (e.g. category, claimable). Booleans print
# lowercased; a missing state or field prints the empty string.
wf_state_field() {
  local wf_file=$1 state=$2 field=$3
  TS_S="$state" TS_F="$field" python3 - "$wf_file" <<'PY'
import json, os, sys
wf = json.load(open(sys.argv[1]))
s = next((x for x in wf.get("states", []) if x.get("id") == os.environ["TS_S"]), {})
v = s.get(os.environ["TS_F"])
print("" if v is None else (str(v).lower() if isinstance(v, bool) else str(v)))
PY
}

# Resolve the single workflow state in $category reachable from $from. Echoes the
# target id and exits 0 on success; on an absent or ambiguous category it prints
# a message listing the legal moves and exits nonzero, so callers can die cleanly
# rather than guessing.
wf_resolve_target() {
  local wf_file=$1 from=$2 category=$3
  TS_FROM="$from" TS_CAT="$category" python3 - "$wf_file" <<'PY'
import json, os, sys
wf = json.load(open(sys.argv[1]))
frm, cat = os.environ["TS_FROM"], os.environ["TS_CAT"]
by_id = {s.get("id"): s for s in wf.get("states", [])}
legal = [t for t in wf.get("transitions", []) if t.get("from") == frm]
seen = []
for t in legal:
    to = t.get("to")
    if by_id.get(to, {}).get("category") == cat and to not in seen:
        seen.append(to)
if len(seen) == 1:
    print(seen[0]); sys.exit(0)
def fmt(t):
    r = t.get("requires")
    return t["to"] + (" (requires %s)" % ",".join(r) if r else "")
moves = ", ".join(fmt(t) for t in legal) or "(none)"
name = wf.get("name", "?")
if not seen:
    print("no move to a '%s' state from '%s' in workflow '%s'; legal moves: %s"
          % (cat, frm, name, moves))
else:
    print("ambiguous '%s' targets from '%s' (%s); use 'takomo move ID STATE'; legal moves: %s"
          % (cat, frm, ", ".join(seen), moves))
sys.exit(1)
PY
}

# Read one field from the ticket body currently in $REQ_OUT.
ticket_field() {
  python3 -c 'import json,sys; print(json.load(open(sys.argv[1])).get(sys.argv[2],""))' "$REQ_OUT" "$1"
}

cmd_start() {
  local id=${1:-}; [ -n "$id" ] || die "start: ID is required"
  api GET "/v1/tickets/$(urlenc "$id")" >/dev/null
  local state project; state=$(ticket_field state); project=$(ticket_field project)
  local wf_file; wf_file=$(mktemp)
  wf_fetch "$project" "$wf_file"
  if [ "$(wf_state_field "$wf_file" "$state" category)" = "in_progress" ]; then
    rm -f "$wf_file"; echo "$id already in progress ($state)"; return
  fi
  # Claim first when the current state is claimable and we do not already hold it.
  if [ -z "$(fence_load "$id")" ] && [ "$(wf_state_field "$wf_file" "$state" claimable)" = "true" ]; then
    api POST "/v1/tickets/$(urlenc "$id")/claim" '{}' >/dev/null
    local fence; fence=$(save_fence_from_response "$id")
    echo "claimed $id  (fence $fence saved)"
  fi
  local target
  if ! target=$(wf_resolve_target "$wf_file" "$state" in_progress); then
    rm -f "$wf_file"; die "start: $target"
  fi
  rm -f "$wf_file"
  do_transition "$id" "$target"
}

# done / block / cancel — resolve the terminal/blocked target from the ticket's
# current state in its project workflow, instead of assuming a fixed state id.
category_move() {
  local verb=$1 category=$2 id=${3:-}
  [ -n "$id" ] || die "$verb: ID is required"
  api GET "/v1/tickets/$(urlenc "$id")" >/dev/null
  local state project; state=$(ticket_field state); project=$(ticket_field project)
  local wf_file; wf_file=$(mktemp)
  wf_fetch "$project" "$wf_file"
  local target
  if ! target=$(wf_resolve_target "$wf_file" "$state" "$category"); then
    rm -f "$wf_file"; die "$verb: $target"
  fi
  rm -f "$wf_file"
  do_transition "$id" "$target"
}

