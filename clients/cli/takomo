cmd_archive() {
  local id="" state="" project=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --state)   state=$2; shift 2 ;;
      --project) project=$2; shift 2 ;;
      -*) die "archive: unknown flag $1" ;;
      *) if [ -z "$id" ]; then id=$1; else die "archive: unexpected argument '$1'"; fi; shift ;;
    esac
  done
  if [ -n "$state" ]; then
    [ -z "$id" ] || die "archive: give either an ID or --state, not both"
    case "$state" in done|cancelled) ;; *) die "archive: --state must be 'done' or 'cancelled'" ;; esac
    project=$(resolve_project "$project")
    # Page through the (active) tickets in that terminal state and archive each.
    local cursor="" n=0
    while :; do
      local q
      q="?project=$(urlenc "$project")&state=$(urlenc "$state")&limit=200"
      [ -n "$cursor" ] && q="$q&cursor=$(urlenc "$cursor")"
      api GET "/v1/tickets$q" >/dev/null
      local ids; ids=$(python3 -c 'import json,sys; print("\n".join(t["id"] for t in json.load(open(sys.argv[1])).get("items",[])))' "$REQ_OUT")
      local tid
      while IFS= read -r tid; do
        [ -n "$tid" ] || continue
        api POST "/v1/tickets/$(urlenc "$tid")/archive" '{}' >/dev/null
        n=$((n + 1))
      done <<< "$ids"
      cursor=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1])).get("next_cursor") or "")' "$REQ_OUT")
      [ -n "$cursor" ] || break
    done
    echo "archived $n ticket(s) in state $state"
    return
  fi
  [ -n "$id" ] || die "archive: ID (or --state done|cancelled) is required"
  api POST "/v1/tickets/$(urlenc "$id")/archive" '{}' >/dev/null
  echo "archived $id"
}

cmd_unarchive() {
  local id=${1:-}; [ -n "$id" ] || die "unarchive: ID is required"
  api POST "/v1/tickets/$(urlenc "$id")/unarchive" '{}' >/dev/null
  echo "unarchived $id"
}

cmd_deps() {
  local id="" blocks="" tree=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --blocks) blocks=1; shift ;;
      --tree)   tree=1; shift ;;
      -*) die "deps: unknown flag $1" ;;
      *) if [ -z "$id" ]; then id=$1; else die "deps: unexpected argument '$1'"; fi; shift ;;
    esac
  done
  [ -n "$id" ] || die "deps: ID is required"
  local dir="blocked_by"; [ -n "$blocks" ] && dir="blocks"
  local trans="false"; [ -n "$tree" ] && trans="true"
  api GET "/v1/tickets/$(urlenc "$id")/deps?direction=$dir&transitive=$trans" >/dev/null
  TS_TREE="$tree" python3 - "$REQ_OUT" <<'PY'
import json, os, sys
d = json.load(open(sys.argv[1]))
root = d["root"]; direction = d["direction"]; tree = bool(os.environ.get("TS_TREE"))
nodes = {n["id"]: n for n in d.get("nodes", [])}
edges = d.get("edges", [])
def label(nid):
    n = nodes.get(nid)
    return nid if not n else f"{nid}  [{n.get('state','')}]  {n.get('title','')}"
if direction == "blocked_by":
    def neigh(nid): return [e["blocked_by"] for e in edges if e["ticket"] == nid]
    print(f"{root} is blocked by:")
else:
    def neigh(nid): return [e["ticket"] for e in edges if e["blocked_by"] == nid]
    print(f"{root} blocks:")
if tree:
    seen = {root}
    def walk(nid, depth, path):
        for m in sorted(neigh(nid)):
            indent = "  " * (depth + 1)
            if m in path:
                print(indent + label(m) + "  (cycle)"); continue
            if m in seen:
                print(indent + label(m) + "  (seen above)"); continue
            print(indent + label(m)); seen.add(m)
            walk(m, depth + 1, path | {m})
    walk(root, 0, {root})
else:
    ns = sorted(neigh(root))
    if not ns:
        print("  (none)")
    for m in ns:
        print("  " + label(m))
PY
}

cmd_release() {
  local id=${1:-} reason=${2:-released via takomo}
  [ -n "$id" ] || die "release: ID is required"
  local fence; fence=$(fence_load "$id")
  [ -n "$fence" ] || die "release: no local fence for $id; pass --fence via claim first or release manually"
  local data; data=$(TS_F="$fence" TS_R="$reason" python3 -c \
    'import json,os; print(json.dumps({"fence":int(os.environ["TS_F"]),"reason":os.environ["TS_R"]}))')
  api POST "/v1/tickets/$(urlenc "$id")/release" "$data" >/dev/null
  fence_clear "$id"
  echo "released $id"
}

