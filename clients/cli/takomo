# takomo share --project P | --epic ID [--ttl 24h]   mint a shareable, expiring,
#   read-only board link and print the full clickable URL.
# takomo share ls                                    list share metadata
# takomo share revoke ID                             revoke a share
cmd_share() {
  local sub=${1:-}
  case "$sub" in
    ls|list)   shift; cmd_share_ls "$@"; return ;;
    revoke|rm) shift; cmd_share_revoke "$@"; return ;;
  esac
  cmd_share_create "$@"
}

cmd_share_create() {
  local project="" epic="" ttl=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project=$2; shift 2 ;;
      --epic)    epic=$2; shift 2 ;;
      --ttl)     ttl=$2; shift 2 ;;
      -*) die "share: unknown flag $1" ;;
      *) die "share: unexpected argument '$1' (usage: takomo share --project P | --epic ID [--ttl 24h])" ;;
    esac
  done
  [ -n "$project" ] && [ -n "$epic" ] && die "share: give either --project or --epic, not both"
  local kind="" ref=""
  if [ -n "$epic" ]; then
    kind="epic"; ref="$epic"
  else
    project=$(resolve_project "$project")
    kind="project"; ref="$project"
  fi
  local data
  data=$(TS_KIND="$kind" TS_REF="$ref" TS_TTL="$ttl" python3 <<'PY'
import json, os
d = {"kind": os.environ["TS_KIND"], "ref": os.environ["TS_REF"]}
ttl = os.environ.get("TS_TTL", "").strip()
if ttl:
    units = {"d": 86400, "h": 3600, "m": 60, "s": 1}
    if ttl[-1] in units and ttl[:-1].isdigit():
        d["ttl_seconds"] = int(ttl[:-1]) * units[ttl[-1]]
    elif ttl.isdigit():
        d["ttl_seconds"] = int(ttl)
    else:
        raise SystemExit(f"invalid --ttl '{ttl}': use 24h, 7d, 90m, 3600s, or a plain second count")
print(json.dumps(d))
PY
)
  api POST /v1/shares "$data" >/dev/null
  # The store returns a fragment path (/board#s=<token>); build the full URL from
  # the configured base (host root, with any trailing /v1 already stripped).
  TS_BASE="$TAKOMO_URL" python3 - "$REQ_OUT" <<'PY'
import json, os, sys
d = json.load(open(sys.argv[1]))
base = os.environ["TS_BASE"].rstrip("/")
url = base + d.get("path", "")
print(f"share created for {d.get('kind','')} {d.get('ref','')}")
print(f"  id:      {d.get('id','')}")
print(f"  expires: {d.get('expires_at','')}")
print()
print(url)
print()
print("Anyone with this link can view the scoped board (read-only) until it expires.")
PY
}

