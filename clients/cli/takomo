import json, sys
rows = json.load(open(sys.argv[1]))
if not rows:
    print("(no tokens)"); sys.exit()
def proj(p): return "*" if p == "*" else ",".join(p) if isinstance(p, list) else str(p)
print(f"{'ID':<14} {'ACTOR':<22} {'SCOPES':<20} {'PROJECTS':<12} {'REVOKED':<8} LAST USED")
for t in rows:
    print(f"{t.get('id',''):<14} {t.get('actor',''):<22} {','.join(t.get('scopes',[])):<20} "
          f"{proj(t.get('projects')):<12} {('yes' if t.get('revoked_at') else 'no'):<8} {t.get('last_used_at') or 'never'}")
PY
