cmd_watch() {
  local project="" since=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --project) project=$2; shift 2 ;;
      --since)   since=$2; shift 2 ;;
      -*) die "watch: unknown flag $1" ;;
      *) die "watch: unexpected argument '$1'" ;;
    esac
  done
  [ -z "$project" ] && project=${TAKOMO_PROJECT:-}
  local pq=""
  [ -n "$project" ] && pq="&project=$(urlenc "$project")"

  local cursor
  if [ -n "$since" ]; then
    cursor=$since
  else
    # Fast-forward to the current tail so we print only new events.
    cursor=0
    while :; do
      api GET "/v1/events?since=$cursor&wait=0&limit=1000$pq" >/dev/null
      local nc; nc=$(python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); print(d.get("cursor",0))' "$REQ_OUT")
      local cnt; cnt=$(python3 -c 'import json,sys; print(len(json.load(open(sys.argv[1])).get("events",[])))' "$REQ_OUT")
      cursor=$nc
      [ "$cnt" -gt 0 ] || break
    done
  fi
  echo "watching events from cursor $cursor${project:+ (project $project)} — Ctrl-C to stop" >&2

  while :; do
    api GET "/v1/events?since=$cursor&wait=25&limit=500$pq" >/dev/null
    cursor=$(python3 - "$REQ_OUT" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
for e in d.get("events", []):
    payload = e.get("payload") or {}
    bits = []
    for k in ("to", "from", "changed", "fence", "reason", "title"):
        if k in payload and payload[k] not in (None, "", []):
            bits.append(f"{k}={payload[k]}")
    extra = ("  " + " ".join(bits)) if bits else ""
    tk = e.get("ticket") or "-"
    print(f"[{e.get('at','')}] #{e.get('seq')}  {e.get('kind',''):<14} {tk:<14} @{e.get('actor','')}{extra}",
          file=sys.stderr)
print(d.get("cursor", 0))
PY
)
  done
}

# --- import ------------------------------------------------------------------
# Look up a new (takomo) id for an origin id in the id-map file.
import_map_get() { awk -F'\t' -v k="$1" '$1==k{print $2; exit}' "$2"; }

# Drive a freshly created ticket ($1) to its target state via a precomputed
# move list ($2, JSON array of {to, claim}). Best-effort: echoes "ok" or
# "fail:<why>". Claims when an edge requires it, echoes the saved fence, and
# releases any lease left held on a non-terminal target.
import_reach_state() {
  local nid=$1 moves=$2
  local n; n=$(TS_M="$moves" python3 -c 'import json,os; print(len(json.loads(os.environ["TS_M"])))')
  local holding="" i=0
  while [ "$i" -lt "$n" ]; do
    local to claim
    to=$(TS_M="$moves" TS_I="$i" python3 -c 'import json,os; print(json.loads(os.environ["TS_M"])[int(os.environ["TS_I"])]["to"])')
    claim=$(TS_M="$moves" TS_I="$i" python3 -c 'import json,os; print("1" if json.loads(os.environ["TS_M"])[int(os.environ["TS_I"])]["claim"] else "0")')
    if [ "$claim" = "1" ] && [ -z "$holding" ]; then
      local code; code=$(api_try POST "/v1/tickets/$(urlenc "$nid")/claim" '{}')
      [ "$code" = "200" ] || { echo "fail:claim($code)"; return 0; }
      holding=$(save_fence_from_response "$nid")
    fi
    local fence data code
    fence=$(fence_load "$nid")
    data=$(TS_TO="$to" TS_F="$fence" python3 -c 'import json,os; d={"to":os.environ["TS_TO"]};
f=os.environ.get("TS_F","");
d["fence"]=int(f) if f else None;
print(json.dumps({k:v for k,v in d.items() if v is not None}))')
    code=$(api_try POST "/v1/tickets/$(urlenc "$nid")/transition" "$data")
    [ "$code" = "200" ] || { echo "fail:->$to($code)"; return 0; }
    local hasclaim; hasclaim=$(python3 -c 'import json,sys; print(1 if json.load(open(sys.argv[1])).get("claim") else 0)' "$REQ_OUT")
    if [ "$hasclaim" = "0" ]; then fence_clear "$nid"; holding=""; fi
    i=$((i + 1))
  done
  if [ -n "$holding" ] && [ -n "$(fence_load "$nid")" ]; then
    local fence; fence=$(fence_load "$nid")
    api_try POST "/v1/tickets/$(urlenc "$nid")/release" \
      "$(TS_F="$fence" python3 -c 'import json,os; print(json.dumps({"fence":int(os.environ["TS_F"]),"reason":"import: state applied"}))')" >/dev/null
    fence_clear "$nid"
  fi
  echo "ok"
}

cmd_import() {
  local source="" path="" project=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --from)    source=$2; shift 2 ;;
      --project) project=$2; shift 2 ;;
      -*) die "import: unknown flag $1" ;;
      *) path=$1; shift ;;
    esac
  done
  [ -n "$source" ] || die "import: --from takomo|beads|beans is required"
  [ -n "$path" ]   || die "import: PATH (a file, or a directory for beans) is required"
  case "$source" in
    takomo|beads|beans) ;;
    *) die "import: --from must be one of: takomo, beads, beans" ;;
  esac
  [ -e "$path" ] || die "import: no such file or directory: $path"
  project=$(resolve_project "$project")

  # The target workflow (state map + reach planning) and this token's scopes
  # (so planning prefers moves we can actually make) drive the mapping.
  api GET "/v1/projects/$(urlenc "$project")/workflow" >/dev/null
  local wf_file; wf_file=$(mktemp); cp "$REQ_OUT" "$wf_file"
  api GET /v1/whoami >/dev/null
  local myscopes; myscopes=$(python3 -c 'import json,sys; print(",".join(json.load(open(sys.argv[1])).get("scopes",[])))' "$REQ_OUT")

  # Normalize the source + plan each item (create body, relations, state moves).
  local planner; planner=$(import_planner_path)
  local planned; planned=$(mktemp)
  if ! TS_SOURCE="$source" TS_PATH="$path" TS_PROJECT="$project" TS_WF="$wf_file" TS_SCOPES="$myscopes" \
       python3 "$planner" > "$planned"; then
    rm -f "$wf_file" "$planned" "$planner"
    die "import: could not parse/plan the source data (a beans import needs PyYAML: pip install pyyaml)"
  fi
  local total; total=$(grep -c . "$planned" || true)
  [ "${total:-0}" -gt 0 ] || { echo "import: nothing to import (0 items parsed)"; rm -f "$wf_file" "$planned"; return; }
  echo "Importing ${total} item(s) from $source into project '$project'..."

  # Pass A — create (idempotent on origin id: safe to re-run).
  local map fresh; map=$(mktemp); fresh=$(mktemp)
  local created=0 skipped=0 failed=0
  while IFS= read -r item; do
    [ -n "$item" ] || continue
    local origin body idem code
    origin=$(TS_I="$item" python3 -c 'import json,os; print(json.loads(os.environ["TS_I"])["origin_id"])')
    body=$(TS_I="$item" python3 -c 'import json,os; print(json.dumps(json.loads(os.environ["TS_I"])["create_body"]))')
    idem=$(printf '%s' "$origin" | cut -c1-128)
    code=$(api_try POST /v1/tickets "$body" "Idempotency-Key: $idem")
    case "$code" in
      201) created=$((created + 1)) ;;
      200) skipped=$((skipped + 1)) ;;
      *) failed=$((failed + 1)); echo "  ! create failed for origin '$origin' (HTTP $code)" >&2; print_api_error; continue ;;
    esac
    local nid; nid=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["id"])' "$REQ_OUT")
    printf '%s\t%s\n' "$origin" "$nid" >> "$map"
    [ "$code" = "201" ] && printf '%s\n' "$origin" >> "$fresh"
  done < "$planned"

  # Pass B/C/D — relations, comments, state moves for FRESHLY created tickets
  # only (replays are already wired; re-driving them would double comments).
  local rel=0 parents=0 coms=0 states_ok=0 states_skipped=0
  while IFS= read -r item; do
    [ -n "$item" ] || continue
    local origin; origin=$(TS_I="$item" python3 -c 'import json,os; print(json.loads(os.environ["TS_I"])["origin_id"])')
    grep -qxF "$origin" "$fresh" || continue
    local nid; nid=$(import_map_get "$origin" "$map"); [ -n "$nid" ] || continue

    # parent (map origin -> new id).
    local porigin; porigin=$(TS_I="$item" python3 -c 'import json,os; p=json.loads(os.environ["TS_I"]).get("parent"); print(p or "")')
    if [ -n "$porigin" ]; then
      local pnew; pnew=$(import_map_get "$porigin" "$map")
      if [ -n "$pnew" ]; then
        [ "$(api_try PATCH "/v1/tickets/$(urlenc "$nid")" "$(TS_P="$pnew" python3 -c 'import json,os; print(json.dumps({"parent":os.environ["TS_P"]}))')")" = "200" ] && parents=$((parents + 1))
      fi
    fi
    # blocked_by edges.
    local bbs; bbs=$(TS_I="$item" python3 -c 'import json,os; print("\n".join(json.loads(os.environ["TS_I"]).get("blocked_by") or []))')
    local bb
    while IFS= read -r bb; do
      [ -n "$bb" ] || continue
      local bnew; bnew=$(import_map_get "$bb" "$map"); [ -n "$bnew" ] || continue
      if [ "$(api_try POST "/v1/tickets/$(urlenc "$nid")/deps" "$(TS_B="$bnew" python3 -c 'import json,os; print(json.dumps({"blocked_by":os.environ["TS_B"]}))')")" = "201" ]; then
        rel=$((rel + 1))
      fi
    done <<< "$bbs"
    # comments (fresh only, since comments have no idempotency).
    local ncom; ncom=$(TS_I="$item" python3 -c 'import json,os; print(len(json.loads(os.environ["TS_I"]).get("comments") or []))')
    local ci=0
    while [ "$ci" -lt "$ncom" ]; do
      local ctext; ctext=$(TS_I="$item" TS_C="$ci" python3 -c 'import json,os; print(json.loads(os.environ["TS_I"])["comments"][int(os.environ["TS_C"])].get("body",""))')
      if [ -n "$ctext" ]; then
        api_try POST "/v1/tickets/$(urlenc "$nid")/comments" "$(TS_T="$ctext" python3 -c 'import json,os; print(json.dumps({"body":os.environ["TS_T"]}))')" >/dev/null && coms=$((coms + 1))
      fi
      ci=$((ci + 1))
    done
    # state moves.
    local moves; moves=$(TS_I="$item" python3 -c 'import json,os; m=json.loads(os.environ["TS_I"]).get("moves"); print(json.dumps(m) if m else "")')
    if [ -n "$moves" ] && [ "$moves" != "[]" ] && [ "$moves" != "null" ]; then
      local r; r=$(import_reach_state "$nid" "$moves")
      if [ "$r" = "ok" ]; then states_ok=$((states_ok + 1)); else states_skipped=$((states_skipped + 1)); fi
    fi
  done < "$planned"

  rm -f "$wf_file" "$planned" "$map" "$fresh" "$planner"
  echo "Done: $created created, $skipped already-present (replayed), $failed failed."
  echo "  relations: $parents parent link(s), $rel dep edge(s) wired; comments: $coms added."
  echo "  state applied to $states_ok ticket(s); $states_skipped left in the initial state (gated/blocked — origin status preserved in metadata.import.origin_status)."
}

# Write the import planner python to a temp file and echo its path. Kept as a
# heredoc (not inline) because it is large; the caller removes the file.
import_planner_path() {
  local f; f=$(mktemp)
  cat > "$f" <<'PY'
import collections, glob, heapq, json, os, sys

source = os.environ["TS_SOURCE"]
path = os.environ["TS_PATH"]
project = os.environ["TS_PROJECT"]
wf = json.load(open(os.environ["TS_WF"]))
my_scopes = set(s for s in os.environ.get("TS_SCOPES", "").split(",") if s)

states = {s["id"]: s for s in wf.get("states", [])}
initial = wf.get("initial")
transitions = wf.get("transitions", [])
by_cat = {}
for sid, s in states.items():
    by_cat.setdefault(s.get("category"), []).append(sid)

VALID_TYPES = {"epic", "task", "bug", "spike"}
VALID_PRI = {"critical", "high", "normal", "low"}
TYPE_MAP = {"epic": "epic", "milestone": "epic", "task": "task", "feature": "task",
            "story": "task", "chore": "task", "bug": "bug", "defect": "bug",
            "spike": "spike", "research": "spike"}
PRI_MAP = {"critical": "critical", "urgent": "critical", "high": "high", "p1": "high",
           "normal": "normal", "medium": "normal", "p2": "normal", "low": "low",
           "p3": "low", "deferred": "low"}


def map_type(t):
    t = (t or "").strip().lower()
    return TYPE_MAP.get(t, t if t in VALID_TYPES else "task")


def map_priority(p):
    p = ("" if p is None else str(p)).strip().lower()
    return PRI_MAP.get(p, p if p in VALID_PRI else "normal")


def desired_category(status):
    s = (status or "").strip().lower().replace("_", "-")
    beads = {"open": "todo", "in-progress": "in_progress", "closed": "done",
             "done": "done", "deferred": "blocked", "blocked": "blocked",
             "cancelled": "cancelled", "canceled": "cancelled"}
    beans = {"todo": "todo", "draft": "todo", "in-progress": "in_progress",
             "completed": "done", "done": "done", "scrapped": "cancelled",
             "blocked": "blocked"}
    if source == "beads":
        return beads.get(s, "todo")
    if source == "beans":
        return beans.get(s, "todo")
    return None


def pick_target_state(status, category_hint):
    # takomo round-trip: an exact state id wins.
    if source == "takomo" and status in states:
        return status
    cat = category_hint if source == "takomo" else desired_category(status)
    if not cat:
        cat = category_hint or states.get(initial, {}).get("category")
    cands = by_cat.get(cat, [])
    if not cands:
        return initial
    if initial in cands:
        return initial
    if cat in ("done", "cancelled"):
        term = [c for c in cands if states[c].get("terminal")]
        if term:
            return term[0]
    claimable = [c for c in cands if states[c].get("claimable")]
    return (claimable or cands)[0]


def edge_reqs(tr):
    reqs = tr.get("requires", []) or []
    claim = "claim" in reqs
    scopes = [r.split("scope:", 1)[1] for r in reqs if r.startswith("scope:")]
    return claim, scopes


def plan_moves(target):
    if target == initial or not target:
        return []
    adj = collections.defaultdict(list)
    for tr in transitions:
        adj[tr["from"]].append(tr)
    best = {initial: (0, 0)}
    prev = {}
    pq = [(0, 0, initial)]
    while pq:
        unmet, length, node = heapq.heappop(pq)
        if (unmet, length) > best.get(node, (1e9, 1e9)):
            continue
        for tr in adj.get(node, []):
            _, scopes = edge_reqs(tr)
            u = unmet + sum(1 for sc in scopes if sc not in my_scopes)
            l = length + 1
            nb = tr["to"]
            if (u, l) < best.get(nb, (1e9, 1e9)):
                best[nb] = (u, l)
                prev[nb] = (node, tr)
                heapq.heappush(pq, (u, l, nb))
    if target not in prev:
        return None
    out = []
    cur = target
    while cur != initial:
        node, tr = prev[cur]
        claim, _ = edge_reqs(tr)
        out.append({"to": tr["to"], "claim": claim})
        cur = node
    out.reverse()
    return out


def clean_labels(raw):
    out = []
    for l in raw or []:
        l = str(l).strip()
        if l and len(l) <= 100 and l not in out:
            out.append(l)
    return out


def parse_frontmatter(text):
    # returns (dict, body). Requires a leading '---' YAML block.
    import yaml
    if not text.startswith("---"):
        return {}, text
    parts = text.split("\n---", 1)
    # handle both '---\n...\n---\n' forms
    lines = text.splitlines()
    if lines and lines[0].strip() == "---":
        end = None
        for i in range(1, len(lines)):
            if lines[i].strip() == "---":
                end = i
                break
        if end is not None:
            fm = yaml.safe_load("\n".join(lines[1:end])) or {}
            body = "\n".join(lines[end + 1:]).lstrip("\n")
            return (fm if isinstance(fm, dict) else {}), body
    return {}, text


items = []
if source == "takomo":
    for line in open(path):
        line = line.strip()
        if not line:
            continue
        d = json.loads(line)
        items.append({
            "origin_id": d.get("id"),
            "title": d.get("title", ""),
            "body": d.get("body", ""),
            "type": d.get("type", "task"),
            "status": d.get("state", ""),
            "state_category": d.get("state_category"),
            "priority": d.get("priority", "normal"),
            "labels": d.get("labels", []) or [],
            "parent": d.get("parent"),
            "blocked_by": d.get("blocked_by", []) or [],
            "created_at": d.get("created_at"),
            "updated_at": d.get("updated_at"),
            "extra_metadata": d.get("metadata", {}) or {},
            "comments": [{"body": c.get("body", "")} for c in (d.get("comments") or [])],
        })
elif source == "beads":
    for line in open(path):
        line = line.strip()
        if not line:
            continue
        d = json.loads(line)
        bb = d.get("blocked_by")
        if bb is None:
            bb = []
            for dep in (d.get("dependencies") or []):
                if isinstance(dep, dict):
                    if dep.get("type") in (None, "blocks", "blocked-by", "blocked_by"):
                        bb.append(dep.get("id") or dep.get("target") or dep.get("to"))
                else:
                    bb.append(dep)
        items.append({
            "origin_id": d.get("id") or d.get("issue_id"),
            "title": d.get("title") or d.get("summary") or "",
            "body": d.get("description") or d.get("body") or "",
            "type": d.get("type") or d.get("issue_type") or "task",
            "status": d.get("status", ""),
            "priority": d.get("priority", "normal"),
            "labels": d.get("labels") or d.get("tags") or [],
            "parent": d.get("parent") or d.get("parent_id") or d.get("epic"),
            "blocked_by": [x for x in bb if x],
            "created_at": d.get("created_at") or d.get("created"),
            "updated_at": d.get("updated_at") or d.get("updated"),
            "extra_metadata": {},
            "comments": [{"body": c.get("body") or c.get("text", "")} for c in (d.get("comments") or []) if isinstance(c, dict)],
        })
elif source == "beans":
    root = path
    if os.path.isdir(os.path.join(path, ".beans")):
        root = os.path.join(path, ".beans")
    files = sorted(glob.glob(os.path.join(root, "*.md")) + glob.glob(os.path.join(root, "archive", "*.md")))
    for fp in files:
        text = open(fp).read()
        fm, body = parse_frontmatter(text)
        base = os.path.basename(fp)
        oid = fm.get("id") or base.split("--", 1)[0].rsplit(".md", 1)[0]
        items.append({
            "origin_id": oid,
            "title": fm.get("title", "") or "",
            "body": body or "",
            "type": fm.get("type", "task"),
            "status": fm.get("status", ""),
            "priority": fm.get("priority", "normal"),
            "labels": fm.get("tags") or [],
            "parent": fm.get("parent"),
            "blocked_by": fm.get("blocked_by") or [],
            "created_at": fm.get("created_at"),
            "updated_at": fm.get("updated_at"),
            "extra_metadata": {},
            "comments": [],
        })

for it in items:
    tgt = pick_target_state(it.get("status"), it.get("state_category"))
    moves = plan_moves(tgt)
    md = {
        "import.source": source,
        "import.origin_id": it.get("origin_id"),
        "import.origin_status": it.get("status") or "",
    }
    for k in ("created_at", "updated_at"):
        if it.get(k):
            md[f"import.{k}"] = it[k]
    if it.get("parent"):
        md["import.origin_parent"] = it["parent"]
    if it.get("blocked_by"):
        md["import.origin_blocked_by"] = it["blocked_by"]
    for k, v in (it.get("extra_metadata") or {}).items():
        md.setdefault(k, v)
    title = (it.get("title") or "").strip() or "(untitled import)"
    create_body = {
        "project": project,
        "title": title[:300],
        "type": map_type(it.get("type")),
        "priority": map_priority(it.get("priority")),
        "metadata": md,
    }
    if it.get("body"):
        create_body["body"] = it["body"]
    labels = clean_labels(it.get("labels"))
    if labels:
        create_body["labels"] = labels
    print(json.dumps({
        "origin_id": it.get("origin_id"),
        "create_body": create_body,
        "parent": it.get("parent"),
        "blocked_by": [b for b in (it.get("blocked_by") or []) if b],
        "target_state": tgt,
        "moves": moves,
        "comments": it.get("comments") or [],
    }))
PY
  echo "$f"
}

cmd_help() {
  cat <<'EOF'
takomo — command-line client for the takomo

Environment (or run `takomo init` to write repo-local .takomo/ config):
  TAKOMO_URL      /v1 base, e.g. https://host/v1        (required)
  TAKOMO_TOKEN    bearer token                          (required)
  TAKOMO_PROJECT  default project when --project omitted (optional)
  TAKOMO_ACTOR    your actor name, for `ls --mine`       (optional)

Onboarding & identity:
  takomo init [PROJECT] [--workflow simple|FILE] [--url URL] [--actor NAME]
         create/prepare a project for THIS git repo and write .takomo/ config
  takomo whoami              show this token's actor, scopes, and projects

Token administration (admin scope):
  takomo token create --actor NAME [--scopes read,write] [--projects P] [--expires 90d]
  takomo token ls
  takomo token revoke ID

Project administration (admin scope):
  takomo project rm ID [--force]
         cascade-delete a project and ALL its tickets, comments, deps, and
         events. Refused if a ticket has an active claim unless --force is given.
         Tokens scoped to the project are left as-is (revoke with `takomo token revoke`).

Finding & creating work:
  takomo new [--project P] [--type task|bug|epic|spike] [--priority critical|high|normal|low]
         [--parent ID] [--label L]... [--body TEXT] TITLE
  takomo ls  [--project P] [--state S] [--label L]... [--mine] [--archived] [-q TEXT]
  takomo ready [--project P]
  takomo roadmap [--project P]   epic progress rollup: a bar + child counts per epic,
                                 contradiction flags, and a "(no epic)" bucket
  takomo show ID

Claiming & progressing (the fence is remembered locally after a claim):
  takomo claim ID            claim a specific ready ticket
  takomo next [--project P] [--wait SECS]   atomically claim the next ready ticket
  takomo start ID            claim if needed, then move to the workflow's in-progress state
  takomo done ID             move to the workflow's done state
  takomo block ID            move to the workflow's blocked state
  takomo cancel ID           move to the workflow's cancelled state
  takomo move ID STATE       move to an arbitrary workflow state
  takomo release ID [REASON] return the ticket to the queue

Annotating:
  takomo comment ID TEXT
  takomo link ID [--pr URL] [--branch B] [--env URL] [--run URL]
  takomo dep ID --blocked-by OTHER
  takomo deps ID [--blocks] [--tree]   show what blocks ID (or, with --blocks, what
                                   ID blocks); --tree walks the chain transitively

Shareable read-only web views (write scope):
  takomo share --project P [--ttl 24h]   mint a read-only, expiring link to a whole
                                     project's board; prints the full URL
  takomo share --epic ID [--ttl 24h]     mint a link to a ticket + its full subtree
  takomo share ls                        list shares (id, kind, ref, expiry)
  takomo share revoke ID                 revoke a share immediately
         --ttl accepts 24h, 7d, 90m, 3600s (default 24h, max 30d). The token
         rides in the URL fragment (#s=...); anyone with the link can view until
         it expires.

Archiving (hides tickets from default list/ready/board/metrics views):
  takomo archive ID                    archive one ticket
  takomo archive --state done|cancelled [--project P]   bulk-archive terminal tickets
  takomo unarchive ID                  return a ticket to the default views
  takomo ls --archived                 list archived tickets

Portability & observability:
  takomo export [--project P] [--out FILE]   JSONL of tickets + comments + deps
  takomo import --from takomo|beads|beans PATH [--project P]
         load data in (Idempotency-Key = origin id, so re-import is safe);
         takomo FILE round-trips `takomo export`; beans PATH is a repo/.beans dir
  takomo watch  [--project P] [--since N]     tail the event log, printing new events
  takomo metrics                              ticket/claim/event counts for the store

Any --fence is auto-included from the local claim; transitions print the
allowed moves and a remedy when the workflow rejects them.
EOF
}

main() {
  local cmd=${1:-help}
  if [ $# -gt 0 ]; then shift; fi
  case "$cmd" in
    help|-h|--help) cmd_help; return ;;
    init)    cmd_init "$@"; return ;;
  esac
  require_env
  case "$cmd" in
    whoami)  cmd_whoami "$@" ;;
    token)   cmd_token "$@" ;;
    project) cmd_project "$@" ;;
    new)     cmd_new "$@" ;;
    ls|list) cmd_ls "$@" ;;
    ready)   cmd_ready "$@" ;;
    roadmap) cmd_roadmap "$@" ;;
    show)    cmd_show "$@" ;;
    claim)   cmd_claim "$@" ;;
    next)    cmd_next "$@" ;;
    start)   cmd_start "$@" ;;
    done)    cmd_done "$@" ;;
    block)   cmd_block "$@" ;;
    cancel)  cmd_cancel "$@" ;;
    move)    cmd_move "$@" ;;
    comment) cmd_comment "$@" ;;
    link)    cmd_link "$@" ;;
    dep)     cmd_dep "$@" ;;
    deps)    cmd_deps "$@" ;;
    archive) cmd_archive "$@" ;;
    unarchive) cmd_unarchive "$@" ;;
    release) cmd_release "$@" ;;
    share)   cmd_share "$@" ;;
    export)  cmd_export "$@" ;;
    import)  cmd_import "$@" ;;
    watch)   cmd_watch "$@" ;;
    metrics) cmd_metrics "$@" ;;
    *) die "unknown command '$cmd' (try: takomo help)" ;;
  esac
}

main "$@"
