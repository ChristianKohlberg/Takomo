# --- token administration (admin scope) --------------------------------------

cmd_token() {
  local sub=${1:-}; [ -n "$sub" ] || die "token: usage: takomo token create|ls|revoke ..."
  shift
  case "$sub" in
    create) cmd_token_create "$@" ;;
    ls|list) cmd_token_ls "$@" ;;
    revoke) cmd_token_revoke "$@" ;;
    *) die "token: unknown subcommand '$sub' (create|ls|revoke)" ;;
