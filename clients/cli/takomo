cmd_project() {
  local sub=${1:-}; [ -n "$sub" ] || die "project: usage: takomo project rm ID [--force]"
  shift
  case "$sub" in
    rm|remove|delete) cmd_project_rm "$@" ;;
    *) die "project: unknown subcommand '$sub' (rm)" ;;
  esac
}

# takomo project rm ID [--force] — cascade-delete a project and ALL of its tickets,
# comments, deps, and events. Refused (409) if any ticket has an active claim
# unless --force is given. Tokens scoped to the project are left as-is; they
# simply stop resolving once it is gone (revoke them with `takomo token revoke`).
cmd_project_rm() {
  local id="" force=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --force) force=1; shift ;;
      -*) die "project rm: unknown flag $1" ;;
      *) if [ -z "$id" ]; then id=$1; else die "project rm: unexpected argument '$1'"; fi; shift ;;
    esac
  done
  [ -n "$id" ] || die "project rm: ID is required"

  # Confirm the project exists (the list is authoritative; metrics omits empty
  # projects). Die early with a clear message if it is unknown to this token.
  api GET /v1/projects >/dev/null
  python3 - "$REQ_OUT" "$id" <<'PY'
import json, sys
rows = json.load(open(sys.argv[1]))
pid = sys.argv[2]
if not any(p.get("id") == pid for p in rows):
    sys.stderr.write(f"project rm: no project '{pid}' visible to this token\n")
    sys.exit(2)
PY

  # Pre-delete summary of what will cascade (metrics has per-project counts;
  # a project with no tickets simply won't appear there — treat as empty).
  api GET /v1/metrics >/dev/null
  python3 - "$REQ_OUT" "$id" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
pid = sys.argv[2]
p = (d.get("projects") or {}).get(pid) or {}
print(f"deleting project '{pid}': {p.get('total',0)} ticket(s), {p.get('open_claims',0)} open claim(s)")
bs = p.get("by_state") or {}
if bs:
    print("  by state: " + ", ".join(f"{k}={v}" for k, v in sorted(bs.items())))
print("  cascade removes every ticket, comment, dependency, and event under it.")
PY

  local path; path="/v1/projects/$(urlenc "$id")"
  [ -n "$force" ] && path="$path?force=true"
  api DELETE "$path" >/dev/null
  echo "deleted project $id"
}

