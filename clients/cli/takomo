# The `simple` plain-tracker workflow, embedded so `takomo init` works even when the
# CLI is symlinked away from the repo. Kept in sync with workflows/simple.yaml.
simple_workflow_json() {
  cat <<'EOF'
{"name":"simple","initial":"todo","states":[
  {"id":"draft","category":"todo","claimable":false,"terminal":false},
  {"id":"todo","category":"todo","claimable":true,"terminal":false},
  {"id":"in_progress","category":"in_progress","claimable":false,"terminal":false},
  {"id":"blocked","category":"blocked","claimable":false,"terminal":false},
  {"id":"done","category":"done","claimable":false,"terminal":true},
  {"id":"cancelled","category":"cancelled","claimable":false,"terminal":true}],
 "transitions":[
  {"from":"draft","to":"todo"},{"from":"draft","to":"cancelled"},
  {"from":"todo","to":"in_progress","requires":["claim"]},{"from":"todo","to":"cancelled"},
  {"from":"in_progress","to":"done","requires":["claim"]},{"from":"in_progress","to":"blocked"},
  {"from":"in_progress","to":"todo"},{"from":"in_progress","to":"cancelled"},
  {"from":"blocked","to":"in_progress","requires":["claim"]},{"from":"blocked","to":"todo"},
  {"from":"blocked","to":"cancelled"}]}
EOF
}

# Resolve the workflow spec to a JSON body on stdout.
# $1 = --workflow value ("" | "simple" | path to .json/.yaml)
workflow_json() {
  local wf=${1:-simple}
  if [ -z "$wf" ] || [ "$wf" = "simple" ]; then
    # Prefer the shipped simple.yaml (single source) if reachable + PyYAML is
    # present; otherwise fall back to the embedded JSON.
    local script_real repo_wf
    script_real=$(readlink -f "$0" 2>/dev/null || echo "$0")
    repo_wf="$(dirname "$script_real")/../../workflows/simple.yaml"
    if [ -f "$repo_wf" ] && python3 -c 'import yaml' 2>/dev/null; then
      TS_WF="$repo_wf" python3 -c 'import json,os,yaml; print(json.dumps(yaml.safe_load(open(os.environ["TS_WF"]))))'
    else
      simple_workflow_json
    fi
    return
  fi
  [ -f "$wf" ] || die "init: workflow file not found: $wf"
  case "$wf" in
    *.json) cat "$wf" ;;
    *.yaml|*.yml)
      python3 -c 'import yaml' 2>/dev/null || die "init: reading a .yaml workflow needs PyYAML (pip install pyyaml), or pass a .json file"
      TS_WF="$wf" python3 -c 'import json,os,yaml; print(json.dumps(yaml.safe_load(open(os.environ["TS_WF"]))))' ;;
    *) die "init: --workflow must be 'simple', a .json, or a .yaml file" ;;
  esac
}

# sanitize a string into a valid project id: ^[a-z][a-z0-9-]{1,15}$
sanitize_project_id() {
  TS_RAW="$1" python3 <<'PY'
import os, re, sys
raw = os.environ["TS_RAW"].lower()
s = re.sub(r'[^a-z0-9-]+', '-', raw).strip('-')
s = re.sub(r'-{2,}', '-', s)
if s and not s[0].isalpha():
    s = "p-" + s
s = s[:16].rstrip('-')
if len(s) < 2:
    print("", end=""); sys.exit()
print(s)
PY
}

cmd_init() {
  local project="" workflow="simple" url="" actor=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --workflow) workflow=$2; shift 2 ;;
      --url)      url=$2; shift 2 ;;
      --actor)    actor=$2; shift 2 ;;
      -*) die "init: unknown flag $1" ;;
      *) project=$1; shift ;;
    esac
  done

  # URL + admin token: explicit flag > env/config. The token in TAKOMO_TOKEN
  # is the admin token used to provision; the agent token is minted below.
  [ -n "$url" ] && export TAKOMO_URL="$url"
  load_takomo_config
  [ -n "${TAKOMO_URL:-}" ]   || die "init: no store URL; pass --url https://host/v1 or set TAKOMO_URL"
  [ -n "${TAKOMO_TOKEN:-}" ] || die "init: no admin token; set TAKOMO_TOKEN to an admin-scoped token to provision with"
  TAKOMO_URL="${TAKOMO_URL%/}"; TAKOMO_URL="${TAKOMO_URL%/v1}"

  # 1. Resolve the git repo root and project id.
  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || die "init: not inside a git repository (run this at a repo root)"
  if [ -z "$project" ]; then
    project=$(sanitize_project_id "$(basename "$repo_root")")
    [ -n "$project" ] || die "init: could not derive a valid project id from '$(basename "$repo_root")'; pass one explicitly: takomo init PROJECT"
  else
    local clean; clean=$(sanitize_project_id "$project")
    [ "$clean" = "$project" ] || die "init: project id '$project' is invalid; must match ^[a-z][a-z0-9-]{1,15}\$ (e.g. '$clean')"
  fi
  [ -z "$actor" ] && actor="agent:$project"
  echo "Onboarding '$repo_root' onto takomo at $TAKOMO_URL"
  echo "  project: $project"

  # 2. Create the project if missing, then apply the workflow.
  local wf_body; wf_body=$(workflow_json "$workflow")
  local created; created=$(TS_P="$project" TS_WF="$wf_body" python3 <<'PY'
import json, os
print(json.dumps({"id": os.environ["TS_P"], "name": os.environ["TS_P"], "workflow": json.loads(os.environ["TS_WF"])}))
PY
)
  local code
  code=$(curl -sS -o "$REQ_OUT" -w '%{http_code}' -X POST "$TAKOMO_URL/v1/projects" \
    -H "Authorization: Bearer $TAKOMO_TOKEN" -H "Content-Type: application/json" --data-binary "$created") \
    || die "init: request failed reaching $TAKOMO_URL"
  if [ "$code" = "201" ]; then
    echo "  created project + applied '$workflow' workflow"
  elif [ "$code" = "409" ]; then
    echo "  project exists; updating workflow to '$workflow'"
    api PUT "/v1/projects/$(urlenc "$project")/workflow" "$wf_body" >/dev/null
  else
    python3 - "$REQ_OUT" "$code" >&2 <<'PY'
import json, sys
try: d = json.load(open(sys.argv[1]))
except Exception: print(f"HTTP {sys.argv[2]}: {open(sys.argv[1]).read()[:400]}"); sys.exit(1)
print(f"HTTP {sys.argv[2]}  [{d.get('code','?')}] {d.get('message','')}")
if d.get('remedy'): print('remedy: ' + d['remedy'])
PY
    die "init: could not create project (HTTP $code)"
  fi

  # 3. Mint a read,write agent token scoped to this project.
  local tok_body; tok_body=$(TS_ACTOR="$actor" TS_P="$project" python3 <<'PY'
import json, os
print(json.dumps({"actor": os.environ["TS_ACTOR"], "scopes": ["read", "write"], "projects": [os.environ["TS_P"]]}))
PY
)
  api POST /v1/tokens "$tok_body" >/dev/null
  local agent_token; agent_token=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["token"])' "$REQ_OUT")
  [ -n "$agent_token" ] || die "init: token mint returned no plaintext"
  echo "  minted agent token for $actor (scopes read,write on $project)"

  # 4. Write repo-local config + token; gitignore the token.
  local cfgdir="$repo_root/.takomo"
  mkdir -p "$cfgdir"
  {
    echo "url=$TAKOMO_URL/v1"
    echo "project=$project"
  } > "$cfgdir/config"
  ( umask 177; printf '%s' "$agent_token" > "$cfgdir/token" )
  chmod 600 "$cfgdir/token" 2>/dev/null || true
  local gi="$repo_root/.gitignore"
  if ! { [ -f "$gi" ] && grep -qxF '.takomo/token' "$gi"; }; then
    printf '\n# takomo agent token (secret)\n.takomo/token\n' >> "$gi"
    echo "  gitignored .takomo/token"
  fi
  echo "  wrote .takomo/config and .takomo/token"

  # 5. Verify the agent token works against the new project.
  echo
  echo "Verifying with the new agent token..."
  local ready_out
  ready_out=$(cd "$repo_root" && TAKOMO_URL="$TAKOMO_URL/v1" TAKOMO_TOKEN="$agent_token" \
    TAKOMO_PROJECT="$project" "$0" ready 2>&1) || die "init: verification (takomo ready) failed: $ready_out"
  echo "  takomo ready -> ${ready_out:-ok}"

  cat <<EOF

Done, project '$project' is live on the store.
Next steps (run from anywhere inside this repo — config is auto-loaded):
  takomo new "First task"        create a ticket
  takomo ready                   see what's claimable
  takomo next                    claim the next ready ticket
  takomo done <id>               finish it

Commit .takomo/config to share the store URL + project with the team.
The secret token in .takomo/token stays local (gitignored).
EOF
}

